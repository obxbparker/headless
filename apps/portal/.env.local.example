# OBx Platform Sanity project (internal — intake submissions).
# Copy this to .env.local and fill in real values. .env.local is gitignored.

NEXT_PUBLIC_SANITY_PROJECT_ID=replace-me
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-14

# Write token from Sanity Manage → API → Tokens (Editor permission or higher).
# Server-only — never prefix with NEXT_PUBLIC_, never commit.
SANITY_WRITE_TOKEN=replace-me
