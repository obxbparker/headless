# Sanity — set per client site at spawn time
# Get these from sanity.io/manage > your project > API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-13

# Optional: server-side read token for previewing draft content.
# Leave blank in production; set when implementing preview mode.
SANITY_API_READ_TOKEN=
