# OuterBox AI Engine — credentials
# Copy to .env (gitignored) and fill in real values.
# IMPORTANT: never put real keys in this file — this file is committed.

# Anthropic API key. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Portal Sanity project (where intakes live). Defaults baked in below.
PORTAL_SANITY_PROJECT_ID=ka9se3h4
PORTAL_SANITY_DATASET=production
PORTAL_SANITY_API_VERSION=2026-05-14
# Token for the portal project. Generate at:
# https://www.sanity.io/manage/project/ka9se3h4/api/tokens
# Editor role is needed if you want to also seed test intakes from the CLI;
# Viewer is enough for read-only generation runs.
PORTAL_SANITY_TOKEN=

# Optional model override. Defaults to claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6
