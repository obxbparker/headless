{
  "name": "@outerbox-client/smoketest-roofing",
  "version": "0.0.0",
  "private": true,
  "description": "Client site for Smoketest Roofing",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "pages:build": "next-on-pages",
    "pages:deploy": "wrangler pages deploy .vercel/output/static",
    "pages:preview": "wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@outerbox/sanity-schemas": "workspace:*",
    "@outerbox/ui": "workspace:*",
    "@sanity/image-url": "^1.1.0",
    "@sanity/vision": "^3.74.1",
    "next": "^15.1.4",
    "next-sanity": "^9.8.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanity": "^3.74.1",
    "styled-components": "^6.1.14"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vercel": "^39.2.2",
    "wrangler": "^4.90.0"
  }
}
